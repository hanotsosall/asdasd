# Обязательные
BOT_TOKEN=8123456789:AAH...твой_токен_от_BotFather
ADMIN_ID=123456789          # твой Telegram ID (узнай у @userinfobot)

# Опционально, но сильно расширяет возможности
OPENAI_API_KEY=sk-...       # ключ от OpenAI (chatGPT) – для генерации писем

# Twitter API (получить на developer.twitter.com)
TWITTER_API_KEY=your_api_key
TWITTER_API_SECRET=your_api_secret
TWITTER_BEARER_TOKEN=your_bearer_token

# VK Access Token (можно получить через https://vkhost.github.io/)
VK_ACCESS_TOKEN=ваш_токен_vk

# Instagram (лучше использовать логин/пароль, но instagrapi может работать и с сессией)
INSTA_USERNAME=your_instagram_login
INSTA_PASSWORD=your_instagram_password

# Have I Been Pwned API ключ (опционально, можно без него)
HIBP_API_KEY=your_hibp_key
